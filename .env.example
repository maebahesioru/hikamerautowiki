# この Next アプリをデプロイしたときの origin（末尾スラッシュなし推奨）。OG・canonical・sitemap / robots の絶対 URL に使用。未設定時はビルド時に http://localhost:3000 が使われる
# NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# --- インターネット公開時の API 保護（どちらも未設定なら制限なし＝ローカル開発向け）---
# サーバー側の共有シークレット（設定時は全 /api を認証。/api/health は除外）
# HIKAMER_API_SECRET=long-random-string
# ブラウザから付けるヘッダー用（上と同じ値。公開バンドルに含まれるため IP 制限と併用推奨）
# NEXT_PUBLIC_HIKAMER_API_SECRET=long-random-string
# カンマ区切り（例: 自宅 IP,127.0.0.1）。設定時はいずれかの IP からのみ許可
# HIKAMER_API_ALLOWED_IPS=127.0.0.1,::1
# GET /api/health で missing 配列まで返す（運用者向け）
# HIKAMER_EXPOSE_ENV_HEALTH=1

# OpenAI 互換 API（新しいフォルダーと同じゲートウェイ）
OPENAI_API_KEY=
# OpenAI 互換のベース URL（末尾の / は任意。自前ゲートウェイなら例: http://127.0.0.1:2048/v1）
OPENAI_API_BASE=https://api.openai.com/v1
# 任意: 1 モデルに固定。未設定時は gemini 系を順に試行（openaiCompat.ts の OPENAI_MODELS）
# OPENAI_MODEL=gemini-3-flash-preview

# 任意: OpenAI 互換 chat/completions の 1 回の HTTP 打ち切り（ms。既定 180000）。無応答で固まるのを防ぐ
# HIKAMER_OPENAI_FETCH_TIMEOUT_MS=180000
# 任意: ストリーミング時の SSE 本文読み取り全体の上限（ms）。0 または未設定で無制限。長文 wikitext 生成で打ち切られたら大きくする
# HIKAMER_OPENAI_STREAM_MAX_MS=0
# 任意: ストリーム要求に stream_options.include_usage を付ける（既定オン）。未対応ゲートウェイで 400 になるとき 0
# HIKAMER_OPENAI_STREAM_INCLUDE_USAGE=

# MediaWiki API（既定はヒカマーwiki）
WIKI_API_URL=https://hikamers.net/api.php
# 任意: X 共有ボタンで貼る記事 URL のベース（未設定時は https://hikamers.net/wiki）
# NEXT_PUBLIC_WIKI_ARTICLE_BASE=https://hikamers.net/wiki
# 反映（dry-run でない実行）のとき必須（前後の空白は無視されます）
# ボットパスワード利用時: ユーザー名は「利用者名@ボット名」（Special:BotPasswords で発行）
WIKI_USERNAME=
WIKI_PASSWORD=

# Yahoo リアルタイム検索（ツイート取得・任意で上書き）
# YAHOO_REALTIME_USER_AGENT=
# YAHOO_REALTIME_REFERER=https://search.yahoo.co.jp/realtime/search

# Yahoo!ウェブ検索（search.yahoo.co.jp のウェブタブ HTML を解析。編集・ファクトチェック AI の補足材料）
# 既定は有効。無効にするときだけ:
# HIKAMER_YAHOO_WEB_SEARCH=0
# ツイート検索クエリの先頭から何本までウェブ検索するか（既定 3、最大 8）
# HIKAMER_WEB_SEARCH_MAX_QUERIES=3
# ウェブ検索で集めるヒットの合計上限（既定 15、最大 40）
# HIKAMER_WEB_SEARCH_MAX_HITS=15
# YAHOO_WEB_SEARCH_USER_AGENT=
# YAHOO_WEB_SEARCH_REFERER=https://search.yahoo.co.jp/

# FxTwitter / FixTweet（api.fxtwitter.com）— マージ後ツイートの画像・プロフィール URL を補完
# 認証不要。無効化する場合: FXTWITTER_MEDIA_ENRICH=0。補完は件数分 Promise.all で並列
# 既定: DB/Yahoo でプロフィール画像と投稿画像の両方が取れているツイートだけ FxTwitter を叩く（速い）
# 全 ID で叩く（旧挙動）: FXTWITTER_MEDIA_ENRICH_ALL=1
# FXTWITTER_MEDIA_ENRICH=
# FXTWITTER_MEDIA_ENRICH_ALL=
# FXTWITTER_USER_AGENT=

# Wiki 保存前に [https://pbs.twimg.com/...] を <img> に変換（既定オフ。1 のときのみ。本文で img が解釈される Wiki のみ）
# HIKAMER_TWIMG_BRACKET_TO_IMG=

# 反映時に pbs.twimg.com の画像をダウンロードして Wiki にアップロードし [[File:...]] に置換（0 で無効・ボットに upload 権限が必要）
# HIKAMER_UPLOAD_TWIMG=
# HIKAMER_TWIMG_DOWNLOAD_USER_AGENT=

# 新しいフォルダーと同じ PostgreSQL（tweets テーブル・任意）
# DATABASE_URL=postgresql://...
# Yahoo + DB マージ後のツイート合計上限（既定 6000）
# HIKAMER_TOTAL_TWEET_LIMIT=6000
# 検索クエリ生成 AI に渡す「ページ名ブートストラップ」ツイートの最大件数（既定 6000＝ツイート合計上限と同じ）
# HIKAMER_QUERY_BOOTSTRAP_TWEET_MAX=6000
# 検索クエリ生成 AI に載せる現在記事 wikitext の最大文字数（既定 100000）
# HIKAMER_QUERY_SUGGEST_WIKITEXT_MAX_CHARS=100000
# wikitext 編集・ファクトチェック AI に渡すツイート最大件数（既定 6000）
# HIKAMER_COMPOSE_TWEET_MAX=6000
# 1 のとき参考ツイートプロンプトを従来の日本語ラベル・長い説明に戻す（既定は圧縮表記）
# HIKAMER_TWEET_PROMPT_VERBOSE=1
# 検索クエリを何本同時に処理するか（1〜16。大きいと DB / Wiki / Yahoo がタイムアウトしやすい。既定 4）
# さらに速くしたいときは 6〜8（Postgres pool max は 8）。不安定なら 2
# HIKAMER_SEARCH_CONCURRENCY=4
